{
    "id": null,
    "title": "ML API Dashboard",
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "type": "graph",
        "title": "Requests Per Second",
        "targets": [
          {
            "expr": "rate(request_total[1m])",
            "legendFormat": "{{endpoint}} - {{status}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "type": "graph",
        "title": "Request Latency",
        "targets": [
          {
            "expr": "rate(request_latency_secounds_sum[1m]) / rate(request_latency_secounds_count[1m])",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "type": "stat",
        "title": "Total Requests",
        "targets": [
          {
            "expr": "sum(request_total)"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 8
        }
      }
    ]
  }
